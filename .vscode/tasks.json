{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-extension",
      "dependsOrder": "sequence",
      "dependsOn": ["npm: compile", "npm: compile-helpers"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "type": "npm",
      "script": "compile",
      "label": "npm: compile",
      "problemMatcher": "$tsc"
    },
    {
      "type": "npm",
      "script": "compile-helpers",
      "label": "npm: compile-helpers",
      "problemMatcher": []
    },
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "group": "build"
    }
  ]
}
